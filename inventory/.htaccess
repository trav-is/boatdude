RewriteEngine On
RewriteBase /inventory/

# Serve existing files/directories normally
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Send everything else to index.html for SPA client-side routing
RewriteRule . index.html [L]

RewriteEngine On
RewriteBase /inventory/

# Serve existing files and directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Fallback to SPA index for deep links
RewriteRule ^ index.html [QSA,L]



